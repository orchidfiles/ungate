{
	"name": "ungate",
	"displayName": "Ungate",
	"description": "Use Claude, GPT, or MiniMax subscriptions in Cursor from one extension",
	"version": "1.3.2",
	"publisher": "orchidfiles",
	"license": "MIT",
	"pricing": "Free",
	"author": {
		"name": "orchidfiles",
		"email": "orchid@orchidfiles.com",
		"url": "https://orchidfiles.com"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/orchidfiles/ungate.git"
	},
	"bugs": {
		"url": "https://github.com/orchidfiles/ungate/issues"
	},
	"homepage": "https://github.com/orchidfiles/ungate",
	"keywords": [
		"claude",
		"anthropic",
		"chatgpt",
		"gpt",
		"minimax",
		"cursor",
		"proxy",
		"openai",
		"ai"
	],
	"engines": {
		"vscode": "^1.96.0"
	},
	"categories": [
		"Other"
	],
	"icon": "resources/icon.png",
	"activationEvents": [
		"onStartupFinished"
	],
	"main": "./dist/extension.js",
	"contributes": {
		"commands": [
			{
				"command": "ungate.openDashboard",
				"title": "Ungate: Open Dashboard"
			},
			{
				"command": "ungate.copyTunnelUrl",
				"title": "Ungate: Copy Tunnel URL"
			},
			{
				"command": "ungate.restartTunnel",
				"title": "Ungate: Restart Tunnel"
			}
		]
	},
	"scripts": {
		"build": "rm -rf dist && tsup",
		"publish": "ovsx publish out/ungate.vsix",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix"
	},
	"dependencies": {
		"cloudflared": "~0.7.1"
	},
	"devDependencies": {
		"@types/node": "~22.15.35",
		"@types/vscode": "~1.96.0",
		"@ungate/dev-kit": "workspace:*",
		"@vscode/vsce": "~3.2.0",
		"ovsx": "~0.10.10",
		"tsup": "~8.5.1",
		"typescript": "~5.7.0"
	},
	"packageManager": "pnpm@10.24.0"
}