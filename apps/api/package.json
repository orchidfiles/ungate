{
	"name": "@ungate/api",
	"type": "module",
	"scripts": {
		"start": "UNGATE_DB_PATH=$HOME/.ungate/data-dev.db node -r source-map-support/register dist/main.js",
		"build": "pnpm run build:compile && pnpm run build:postbuild",
		"build:bundle": "tsup",
		"build:watch": "tsc-watch -p tsconfig.build.json --onCompilationComplete \"pnpm run build:postbuild\"",
		"build:compile": "tsc -p tsconfig.build.json",
		"build:postbuild": "tsc-alias -p tsconfig.build.json && node node_modules/@ungate/dev-kit/src/fix-esm-imports.mjs dist",
		"lint": "eslint src/",
		"lint:fix": "eslint src/ --fix",
		"test": "vitest run",
		"test:watch": "vitest",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate"
	},
	"dependencies": {
		"@fastify/cors": "~11.2.0",
		"@ungate/shared": "workspace:*",
		"better-sqlite3": "~11.9.1",
		"date-fns": "~4.1.0",
		"drizzle-orm": "~0.43.1",
		"fastify": "~5.8.4",
		"source-map-support": "~0.5.21",
		"tslib": "~2.8.1"
	},
	"devDependencies": {
		"@types/better-sqlite3": "~7.6.13",
		"@types/node": "~22.0.0",
		"@ungate/dev-kit": "workspace:*",
		"drizzle-kit": "~0.31.9",
		"esbuild": "~0.27.4",
		"tsc-alias": "~1.8.16",
		"tsc-watch": "~6.2.1",
		"tsup": "~8.5.1",
		"typescript": "~5.7.0",
		"vite": "~8.0.0",
		"vite-tsconfig-paths": "~5.1.4",
		"vitest": "~4.0.18"
	}
}
