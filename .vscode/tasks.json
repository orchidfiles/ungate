{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "dev-kit build",
			"type": "shell",
			"command": "pnpm run build",
			"options": {
				"cwd": "${workspaceFolder}/packages/dev-kit"
			},
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			},
			"problemMatcher": []
		},
		{
			"label": "shared build-watch",
			"type": "shell",
			"command": "pnpm run build:watch",
			"options": {
				"cwd": "${workspaceFolder}/packages/shared"
			},
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			},
			"problemMatcher": []
		},
		{
			"label": "web build",
			"type": "shell",
			"command": "pnpm run build",
			"options": {
				"cwd": "${workspaceFolder}/apps/web"
			},
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			},
			"problemMatcher": []
		},
		{
			"label": "web build-watch",
			"type": "shell",
			"command": "pnpm run build:watch",
			"options": {
				"cwd": "${workspaceFolder}/apps/web"
			},
			"isBackground": true,
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			},
			"problemMatcher": []
		},
		{
			"label": "extension build",
			"type": "shell",
			"command": "pnpm build",
			"options": {
				"cwd": "${workspaceFolder}/apps/extension"
			},
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": "$tsc"
		},
		{
			"label": "api build-watch",
			"type": "shell",
			"command": "pnpm run build:watch",
			"options": {
				"cwd": "${workspaceFolder}/apps/api"
			},
			"isBackground": true,
			"presentation": {
				"reveal": "always",
				"panel": "dedicated"
			},
			"problemMatcher": []
		},
		{
			"label": "build:watch all",
			"dependsOn": [
				"dev-kit build",
				"shared build-watch",
				"web build-watch",
				"api build-watch"
			],
			"runOptions": {
				"runOn": "default"
			},
			"problemMatcher": []
		}
	]
}
